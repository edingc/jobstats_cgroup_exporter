[Unit]
Description=Jobstats cgroup exporter for Slurm
Documentation=https://github.com/edingc/jobstats_cgroup_exporter
After=slurmd.service

[Service]
# The exporter reads other users' cgroups and process info, which requires root.
User=root
Restart=on-failure
EnvironmentFile=/etc/default/jobstats_cgroup_exporter
ExecStart=/usr/local/bin/jobstats_cgroup_exporter $ARGS
ExecReload=/bin/kill -HUP $MAINPID
TimeoutStopSec=20s
SendSIGKILL=no

[Install]
WantedBy=multi-user.target
